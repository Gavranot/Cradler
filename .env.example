# Environment
ENVIRONMENT=development

# Database
POSTGRES_USER=cradler
POSTGRES_PASSWORD=cradler_dev_password
POSTGRES_DB=cradler
DATABASE_URL=postgresql://cradler:cradler_dev_password@localhost:5432/cradler

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cradler-scraped-data

# Temporal
TEMPORAL_HOST=localhost:7233

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here

# JWT Secret
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Sentry (optional)
SENTRY_DSN=

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api

# Scraper Execution Limits
MAX_SCRAPER_EXECUTION_TIME=600
MAX_CONCURRENT_SCRAPERS=10

# Email (for user verification - to be configured later)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@cradler.com
